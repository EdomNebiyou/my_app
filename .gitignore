# ==========================================
# 1. DEPENDENCIES & PACKAGES
# ==========================================
# Ignores package manager caches across all workspaces
**/node_modules/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# 2. ENVIRONMENT SECRETS & KEYS
# ==========================================
# Keeps system API keys and database strings local
**/.env
**/.env.local
**/.env.*.local

# Allow explicit environment templates to be committed
!**/.env.development
!**/.env.production

# ==========================================
# 3. COMPILED PRODUCTION BUILDS
# ==========================================
# Ignores local production bundles from Git tracking
frontend/dist/
frontend/build/

# ==========================================
# 4. SYSTEM & EDITOR SPECIFIC FILES
# ==========================================
# Cleans out OS and code editor cache footprints
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
